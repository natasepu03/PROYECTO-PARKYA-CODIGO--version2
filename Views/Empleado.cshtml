@{
    ViewData["Title"] = "Dashboard Empleado";
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- BOOTSTRAP 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- TU CSS -->
    <link rel="stylesheet" href="~/css/empleado.css">

    <script>
        function actualizarFechaHora() {
            const ahora = new Date();

            const horas = String(ahora.getHours()).padStart(2, "0");
            const minutos = String(ahora.getMinutes()).padStart(2, "0");
            const segundos = String(ahora.getSeconds()).padStart(2, "0");
            document.getElementById("reloj").textContent = `${horas}:${minutos}:${segundos}`;

            const opcionesFecha = {
                weekday: "long",
                year: "numeric",
                month: "long",
                day: "numeric"
            };
            const fechaTexto = ahora.toLocaleDateString("es-ES", opcionesFecha);
            const fechaCap = fechaTexto.charAt(0).toUpperCase() + fechaTexto.slice(1);
            document.getElementById("fecha").textContent = fechaCap;
        }

        setInterval(actualizarFechaHora, 1000);
        document.addEventListener("DOMContentLoaded", actualizarFechaHora);
    </script>
</head>

<body>

    <!-- BARRA SUPERIOR -->
    <header class="top-bar d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <button class="btn btn-light d-lg-none me-2" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
                ☰
            </button>

            <input type="text" class="search d-none d-md-block" placeholder="Buscar placa, espacio, cliente...">
        </div>

        <div class="top-info centered text-center">
            <span class="date" id="fecha"></span>
            <span class="time" id="reloj">00:00:00</span>
        </div>

        <!-- 🔹 Luego esto se cambiará a Url.Action -->
        <button class="btn-salir" onclick="location.href='login.html'">Salir</button>
    </header>

    <div class="layout d-flex">

        <!-- SIDEBAR -->
        <aside class="sidebar d-none d-lg-block">
            <div class="side-user">
                <img src="~/assets/logo1.jpeg" class="side-logo" alt="logo">
                <h3>María González</h3>
                <span class="badge blue">Empleado</span>
            </div>

            <div class="estado">
                <p class="titulo">Estado del Parqueadero</p>
                <p class="green">● Disponible</p>
                <div class="bar-bg">
                    <div class="bar-fill" style="width: 28%;"></div>
                </div>
                <p class="ocupacion">Ocupación: 28%</p>
            </div>

            <nav class="menu">
                <a class="item active">Dashboard</a>
                <a class="item">Vehículos</a>
                <a class="item">Reservas</a>
                <a class="item">Historial</a>
            </nav>
        </aside>

        <!-- OFFCANVAS -->
        <div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarMenu">
            <div class="offcanvas-header">
                <h5>Menú</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>
            <div class="offcanvas-body">
                <div class="side-user text-center">
                    <img src="~/assets/logo1.jpeg" class="side-logo" alt="logo">
                    <h3>María González</h3>
                    <span class="badge blue">Empleado</span>
                </div>

                <div class="estado mt-3">
                    <p class="titulo">Estado del Parqueadero</p>
                    <p class="green">● Disponible</p>
                    <div class="bar-bg">
                        <div class="bar-fill" style="width: 28%;"></div>
                    </div>
                    <p class="ocupacion">Ocupación: 28%</p>
                </div>

                <nav class="menu mt-3">
                    <a class="item active">Dashboard</a>
                    <a class="item">Vehículos</a>
                    <a class="item">Reservas</a>
                    <a class="item">Historial</a>
                </nav>
            </div>
        </div>

        <!-- CONTENIDO -->
        <main class="contenido container-fluid">
            <h1>Dashboard de Empleado</h1>
            <p class="sub">Bienvenido al sistema de gestión PARKYA</p>

            <section class="row g-3 cards">
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card">
                        <span class="titulo">Espacios Totales</span>
                        <h2>18</h2>
                        <p>espacios</p>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card green">
                        <span class="titulo">Disponibles</span>
                        <h2>9</h2>
                        <p>espacios</p>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card red">
                        <span class="titulo">Ocupados</span>
                        <h2>5</h2>
                        <p>espacios</p>
                    </div>
                </div>
            </section>

            <section class="tabla mt-4">
                <h2>Vehículos Activos</h2>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Placa</th>
                                <th>Tipo</th>
                                <th>Hora Entrada</th>
                                <th>Duración</th>
                                <th>Espacio</th>
                                <th>Estado</th>
                                <th>Propietario</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>ABC123</td>
                                <td>Automóvil</td>
                                <td>13:27</td>
                                <td>2h 0m</td>
                                <td>A-01</td>
                                <td><span class="estado active">Activo</span></td>
                                <td>Juan Pérez</td>
                                <td><button class="salida">Salida</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>
        </main>

    </div>

    <!-- BOOTSTRAP JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>

