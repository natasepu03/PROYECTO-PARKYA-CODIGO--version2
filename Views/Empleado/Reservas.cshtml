@model ParkYa.ViewModels.EmpleadoReservasViewModel
@{
    ViewData["Title"] = "Reservas";
    var nombreCompleto = $"{Model.Empleado.nombre} {Model.Empleado.apellido}";
    var inicial = !string.IsNullOrWhiteSpace(Model.Empleado.nombre)
        ? Model.Empleado.nombre.Substring(0, 1).ToUpper()
        : "E";
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/CSS/empleado.css">
        
</head>

    <body>
        <div class="layout">
            <aside class="sidebar">
                <div class="side-brand">
                    <img src="~/assets/logo1.jpeg" class="side-logo" alt="logo">
                        <div class="brand-text">
                            <h2>ParkYa</h2>
                            <span>Empleado</span>
                        </div>
                    </div>

                    <div class="side-user">
                        <div class="avatar">@inicial</div>
                        <div class="side-user-info">
                            <h3>@nombreCompleto</h3>
                            <p>@Model.Empleado.correo</p>
                        </div>
                    </div>

                    <nav class="menu">

                        <a class="item" asp-controller="Empleado" asp-action="Index">
                            <i class="bi bi-house-door-fill"></i> Inicio
                        </a>

                        <a class="item" asp-controller="Empleado" asp-action="Reportes">
                            <i class="bi bi-bar-chart-fill"></i> Reportes
                        </a>

                        <a class="item" asp-controller="Empleado" asp-action="Reservas">
                            <i class="bi bi-calendar-check-fill"></i> Reservas
                        </a>

                    </nav>
                </aside>
                </aside>

                <main class="main-wrapper">
                    <header class="top-panel">
                        <div class="top-panel-left">
                            <h1>Reservas</h1>
                            <p>Control actual e historial de reservas</p>
                        </div>

                        <div class="top-panel-right">
                            <div class="top-info">
                                <span class="date" id="fecha"></span>
                                <span class="time" id="reloj">00:00:00</span>
                            </div>

                            <div class="top-actions">
                                <button class="btn-pill btn-danger-custom"
                                        onclick="location.href='@Url.Action("Login","Autenticacion")'">
                                    Cerrar sesión
                                </button>
                            </div>
                        </div>
                    </header>

                    <section class="dashboard-grid">
                        <article class="panel-card">
                            <h2>Resumen</h2>
                            <p class="sub">Estado actual e historial</p>

                            <div class="summary-stats">
                                <div class="stat-mini">
                                    <span>Activas o pendientes</span>
                                    <strong>@Model.TotalActivasOPendientes</strong>
                                </div>
                                <div class="stat-mini">
                                    <span>Hoy</span>
                                    <strong>@Model.TotalHoy</strong>
                                </div>
                                <div class="stat-mini">
                                    <span>Semana</span>
                                    <strong>@Model.TotalSemana</strong>
                                </div>
                                <div class="stat-mini">
                                    <span>Mes</span>
                                    <strong>@Model.TotalMes</strong>
                                </div>
                            </div>
                        </article>

                        <article class="panel-card table-card">
                            <h2>Reservas pendientes</h2>
                            <p class="sub">Reservas que requieren seguimiento</p>
                            <div class="mb-3">
                                <input type="text" class="form-control" placeholder="🔍 Buscar por placa o cliente..."
                                    onkeyup="filtrarTabla('tablaPendientes', this.value)">
                            </div>

                            <div class="table-wrap">
                                @if (Model.ReservasActuales.Any())
                                {
                                    <table class="employee-table" id="tablaPendientes">
                                        <thead>
                                            <tr>
                                                <th>Código</th>
                                                <th>Cliente</th>
                                                <th>Placa</th>
                                                <th>Fecha</th>
                                                <th>Hora entrada</th>
                                                <th>Hora salida</th>
                                                <th>Estado</th>
                                                <th>Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.ReservasActuales)
                                            {
                                                <tr>
                                                    <td>@item.CodigoReserva</td>
                                                    <td>@item.Cliente</td>
                                                    <td>@item.Placa</td>
                                                    <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                                    <td>
                                                        @(item.HoraEntrada.HasValue
                                                            ? item.HoraEntrada.Value.ToString(@"hh\:mm")
                                                            : "--")
                                                    </td>
                                                    <td>@(item.HoraSalida.HasValue ? item.HoraSalida.Value.ToString(@"hh\:mm") : "--")
                                                    </td>
                                                    <td>
                                                        <span class="estado-badge
                                                            @(item.Estado == "Pendiente" ? "estado-pendiente" :
                                                            item.Estado == "Activa" ? "estado-activa" :
                                                            item.Estado == "Finalizada" ? "estado-finalizada" :
                                                            item.Estado == "Cancelada" ? "estado-cancelada" :
                                                            "")">
                                                            @item.Estado
                                                        </span>
                                                    </td>
                                                    <td>
                                                        @if (item.Estado == Estado.Pendiente.ToString() || item.Estado ==
                                                                                                                                                        Estado.Activa.ToString())
                                                        {
                                                            <button class="btn-finalizar" onclick="abrirModalFinalizar(
                                                                @item.IdReserva,
                                                                '@(item.HoraReservada?.ToString(@"hh\:mm") ?? "")',
                                                                '@(item.HoraEntrada?.ToString(@"hh\:mm") ?? "")',
                                                                '@(item.HoraSalida?.ToString(@"hh\:mm") ?? "")',
                                                                @item.TarifaHora,
                                                                '@item.Fecha.ToString("yyyy-MM-dd")'
                                                                )">
                                                                Finalizar
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                    
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <div class="empty-state">No hay reservas activas o pendientes.</div>
                                }
                            </div>
                        </article>

                        <article class="panel-card table-card">
                            <h2>Historial del día</h2>
                            <div class="mb-3">
                                <input type="text" class="form-control" placeholder="🔍 Buscar por placa o cliente..."
                                       onkeyup="filtrarTabla('tablaHoy', this.value)">
                            </div>
                            <div class="table-wrap">
                                @if (Model.HistorialHoy.Any())
                                {
                                    <table class="employee-table" id="tablaHoy">
                                        <thead>
                                            <tr>
                                                <th>Código</th>
                                                <th>Cliente</th>
                                                <th>Placa</th>
                                                <th>Fecha</th>
                                                <th>Hora entrada</th>
                                                <th>Hora salida</th>
                                                <th>Estado</th>
                                                <th>Monto</th>
                                            
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.HistorialHoy)
                                            {
                                                <tr>
                                                    <td>@item.CodigoReserva</td>
                                                    <td>@item.Cliente</td>
                                                    <td>@item.Placa</td>
                                                    <td>@item.Fecha.ToString("dd/MM/yyyy")</td>

                                                    <td>
                                                        @(item.HoraEntrada.HasValue
                                                            ? item.HoraEntrada.Value.ToString(@"hh\:mm")
                                                            : "--")
                                                    </td>

                                                    <td>
                                                        @(item.HoraSalida.HasValue
                                                            ? item.HoraSalida.Value.ToString(@"hh\:mm")
                                                            : "--")
                                                    </td>

                                                    <td>
                                                        <span class="estado-badge
                                                            @(item.Estado == "Pendiente" ? "estado-pendiente" :
                                                                                                                            item.Estado == "Activa" ? "estado-activa" :
                                                                                                                            item.Estado == "Finalizada" ? "estado-finalizada" :
                                                                                                                            item.Estado == "Cancelada" ? "estado-cancelada" :
                                                                                                                            "")">
                                                            @item.Estado
                                                        </span>
                                                    </td>
                                                    <td>
                                                        @(item.Monto.HasValue ? item.Monto.Value.ToString("C") : "--")
                                                    </td>
                                                </tr>
                                            }
                                    
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <div class="empty-state">No hay reservas registradas hoy.</div>
                                }
                            </div>
                        </article>

                        <article class="panel-card table-card">
                            <h2>Historial de la semana</h2>
                            <div class="mb-3">
                                <input type="text" class="form-control" placeholder="🔍 Buscar por placa o cliente..."
                                       onkeyup="filtrarTabla('tablaSemana', this.value)">
                            </div>
                            <div class="table-wrap">
                                @if (Model.HistorialSemana.Any())
                                {
                                    <table class="employee-table" id="tablaSemana">
                                        <thead>
                                            <tr>
                                                <th>Código</th>
                                                <th>Cliente</th>
                                                <th>Placa</th>
                                                <th>Fecha</th>
                                                <th>Hora entrada</th>
                                                <th>Hora salida</th>
                                                <th>Estado</th>
                                                <th>Monto</th>
                                            </tr>   
                                                
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.HistorialSemana)
                                            {
                                                <tr>
                                                    <td>@item.CodigoReserva</td>
                                                    <td>@item.Cliente</td>
                                                    <td>@item.Placa</td>
                                                    <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                                    <td>@(item.HoraEntrada.HasValue ? item.HoraEntrada.Value.ToString(@"hh\:mm") : "--")
                                                    </td>
                                                    <td>@(item.HoraSalida.HasValue ? item.HoraSalida.Value.ToString(@"hh\:mm") : "--")
                                                    </td>
                                                    <td>
                                                        <span class="estado-badge
                                                        @(item.Estado == "Pendiente" ? "estado-pendiente" :
                                                            item.Estado == "Activa" ? "estado-activa" :
                                                            item.Estado == "Finalizada" ? "estado-finalizada" :
                                                            item.Estado == "Cancelada" ? "estado-cancelada" :
                                                            "")">
                                                        @item.Estado
                                           </span>
                                                    </td>
                                                    <td>
                                                        @(item.Monto.HasValue ? item.Monto.Value.ToString("C") : "--")
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <div class="empty-state">No hay reservas registradas esta semana.</div>
                                }
                            </div>
                        </article>

                        <article class="panel-card table-card">
                            <h2>Historial del mes</h2>
                            <div class="mb-3">
                                <input type="text" class="form-control" placeholder="🔍 Buscar por placa o cliente..."
                                       onkeyup="filtrarTabla('tablaMes', this.value)">
                            </div>
                            <div class="table-wrap">
                                @if (Model.HistorialMes.Any())
                                {
                                    <table class="employee-table" id="tablaMes">
                                        <thead>
                                            <tr>
                                                <th>Código</th>
                                                <th>Cliente</th>
                                                <th>Placa</th>
                                                <th>Fecha</th>
                                                <th>Hora entrada</th>
                                                <th>Hora salida</th>
                                                <th>Estado</th>
                                                <th>Monto</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.HistorialMes)
                                            {
                                                <tr>
                                                    <td>@item.CodigoReserva</td>
                                                    <td>@item.Cliente</td>
                                                    <td>@item.Placa</td>
                                                    <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                                    <td>@(item.HoraEntrada.HasValue ? item.HoraEntrada.Value.ToString(@"hh\:mm") : "--")
                                                    </td>
                                                    <td>@(item.HoraSalida.HasValue ? item.HoraSalida.Value.ToString(@"hh\:mm") : "--")
                                                    </td>
                                                    <td>
                                                        <span
                                                            class="estado-badge 
                                                            @(item.Estado == "Pendiente" ? "estado-pendiente" :
                                                                item.Estado == "Activa" ? "estado-activa" :
                                                                item.Estado == "Finalizada" ? "estado-finalizada" :
                                                                item.Estado == "Cancelada" ? "estado-cancelada" :
                                                                "")">
                                                            @item.Estado
                                                        </span>    
                                                    </td>
                                                    <td>
                                                        @(item.Monto.HasValue ? item.Monto.Value.ToString("C") : "--")
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <div class="empty-state">No hay reservas registradas este mes.</div>
                                }
                            </div>
                        </article>
                    </section>
                </main>
            </div>
            <div class="modal fade" id="modalFinalizar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-3">

            <div class="modal-header">
                <h5 class="modal-title">Finalizar Reserva</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="reservaId">

                <!-- Hora reservada -->
                <div class="mb-3">
                    <label class="form-label">Hora reservada</label>
                    <input type="text" id="horaReservada" class="form-control" readonly>
                </div>

                
                <div class="mb-3">
                    <label class="form-label">Hora entrada</label>
                    <input type="time" id="horaEntrada" class="form-control">
                </div>

                
                <div class="mb-3">
                    <label class="form-label">Hora salida</label>
                    <input type="time" id="horaSalidaDisplay" class="form-control">
                    <input type="hidden" id="horaSalida">
                </div>

                
                <div class="mb-3">
                    <label class="form-label">Monto calculado</label>
                    <input type="text" id="monto" class="form-control" readonly value="0">
                </div>

            </div>

            <div class="d-flex flex-column align-items-center gap-2 mt-3">
                <button type="button"
                        class="btn btn-accion"
                        onclick="guardarHoraEntrada()">
                        Guardar entrada
                </button>

                <button type="button"
                        class="btn btn-accion"
                        onclick="guardarHoraSalida()">
                        Guardar salida
                </button>
            </div>

        </div>
    </div>
</div>

</div>
            

        </div>
    </div>
</div>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    let tarifaHoraGlobal = 0;

    function actualizarFechaHora() {
        const ahora = new Date();

        const horas = String(ahora.getHours()).padStart(2, "0");
        const minutos = String(ahora.getMinutes()).padStart(2, "0");
        const segundos = String(ahora.getSeconds()).padStart(2, "0");

        const reloj = document.getElementById("reloj");
        const fecha = document.getElementById("fecha");

        if (reloj) {
            reloj.textContent = `${horas}:${minutos}:${segundos}`;
        }

        const opcionesFecha = {
            weekday: "long",
            year: "numeric",
            month: "long",
            day: "numeric"
        };

        const fechaTexto = ahora.toLocaleDateString("es-ES", opcionesFecha);
        const fechaCap = fechaTexto.charAt(0).toUpperCase() + fechaTexto.slice(1);

        if (fecha) {
            fecha.textContent = fechaCap;
        }
    }

    function filtrarTabla(idTabla, valor) {
        const filtro = valor.toLowerCase();
        const tabla = document.getElementById(idTabla);

        if (!tabla) return;

        const filas = tabla.getElementsByTagName("tr");

        for (let i = 1; i < filas.length; i++) {
            const textoFila = filas[i].textContent.toLowerCase();
            filas[i].style.display = textoFila.includes(filtro) ? "" : "none";
        }
    }

    function abrirModalFinalizar(id, horaReservada, horaEntrada, horaSalida, tarifa, fechaReserva) {
    document.getElementById("reservaId").value = id;
    document.getElementById("horaReservada").value = horaReservada || "";
    document.getElementById("horaEntrada").value = horaEntrada || "";
    document.getElementById("horaSalidaDisplay").value = horaSalida || "";
    document.getElementById("horaSalida").value = horaSalida || "";

    tarifaHoraGlobal = parseFloat(tarifa) || 0;

    calcularMonto();

    const modal = new bootstrap.Modal(document.getElementById("modalFinalizar"));
    modal.show();
}

    function calcularMonto() {
    const fechaReserva = document.getElementById("fechaReservadaDisplay")?.value;
    const horaEntrada = document.getElementById("horaEntrada").value;
    const horaSalida = document.getElementById("horaSalidaDisplay").value;

    if (!horaEntrada || !horaSalida) {
        document.getElementById("monto").value = 0;
        return;
    }

    const hoy = new Date().toISOString().split('T')[0];

    const entrada = new Date(`${hoy}T${horaEntrada}`);
    let salida = new Date(`${hoy}T${horaSalida}`);

    if (salida < entrada) {
        salida.setDate(salida.getDate() + 1);
    }

    const horas = (salida - entrada) / (1000 * 60 * 60);

    const monto = Math.max(0, horas) * tarifaHoraGlobal;

    document.getElementById("monto").value = monto.toLocaleString("es-CO", {
        style: "currency",
        currency: "COP",
        minimumFractionDigits: 0
    });
}

    async function guardarHoraEntrada() {
        const id = document.getElementById("reservaId").value;
        const horaEntrada = document.getElementById("horaEntrada").value;

        if (!id || !horaEntrada) {
            alert("Debes ingresar la hora de entrada.");
            return;
        }

        try {
            const response = await fetch("/Empleado/GuardarEntrada", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    id: parseInt(id),
                    horaEntrada: horaEntrada
                })
            });

            const data = await response.json();

            if (data.ok) {
                alert("Hora de entrada guardada correctamente.");
                calcularDiasYHoras();
            } else {
                alert("No se pudo guardar la hora de entrada.");
            }
        } catch (error) {
            console.error(error);
            alert("Ocurrió un error al guardar la hora de entrada.");
        }
    }
    
async function guardarHoraSalida() {
    const id = document.getElementById("reservaId").value;
    const horaSalida = document.getElementById("horaSalidaDisplay").value;

    if (!id || !horaSalida) {
        alert("Debes ingresar la hora de salida.");
        return;
    }

    try {
        const response = await fetch("/Empleado/GuardarSalida", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                id: parseInt(id),
                horaSalida: horaSalida
            })
        });

        const data = await response.json();

        if (data.ok) {
            alert("Hora de salida y monto guardados correctamente.");
            location.reload();
        } else {
            alert(data.mensaje || "No se pudo guardar la hora de salida.");
        }
    } catch (error) {
        console.error(error);
        alert("Ocurrió un error al guardar la hora de salida.");
    }
}


    document.addEventListener("DOMContentLoaded", function () {
        actualizarFechaHora();
        setInterval(actualizarFechaHora, 1000);

        const inputHoraSalida = document.getElementById("horaSalidaDisplay");
        const inputHoraEntrada = document.getElementById("horaEntrada");

        if (inputHoraSalida) {
            inputHoraSalida.addEventListener("input", function () {
                document.getElementById("horaSalida").value = this.value;
                calcularDiasYHoras();
            });
        }

        if (inputHoraEntrada) {
            inputHoraEntrada.addEventListener("input", function () {
                calcularDiasYHoras();
            });
        }
    });
</script>
        </body>

    </html>
