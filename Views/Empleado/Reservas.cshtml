    onclick="abrirModalFinalizar(
        @item.IdReserva,
        '@(item.HoraReservada?.ToString(@"hh\:mm") ?? "")',
        '@(item.HoraEntrada?.ToString(@"hh\:mm") ?? "")',
        @item.TarifaHora,
        '@item.Fecha.ToString("yyyy-MM-dd")'
    )">
    Finalizar
</button>
    }
</td>
                                        </tr>
                                    }
                                    
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="empty-state">No hay reservas activas o pendientes.</div>
                        }
                    </div>
                </article>

                <article class="panel-card table-card">
                    <h2>Historial del día</h2>
                    <div class="mb-3">
    <input type="text" class="form-control"
           placeholder="🔍 Buscar por placa o cliente..."
           onkeyup="filtrarTabla('tablaHoy', this.value)">
</div>
                    <div class="table-wrap">
                        @if (Model.HistorialHoy.Any())
                        {
                            <table class="employee-table" id="tablaHoy">
                                <thead>
                                    <tr>
                                        <th>Código</th>
                                        <th>Cliente</th>
                                        <th>Placa</th>
                                        <th>Fecha</th>
                                        <th>Hora entrada</th>
                                        <th>Hora salida</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.HistorialHoy)
                                    {
                                      <tr>
    <td>@item.CodigoReserva</td>
    <td>@item.Cliente</td>
    <td>@item.Placa</td>
    <td>@item.Fecha.ToString("dd/MM/yyyy")</td>

    <td>
        @(item.HoraEntrada.HasValue 
            ? item.HoraEntrada.Value.ToString(@"hh\:mm") 
            : "--")
    </td>

    <td>
        @(item.HoraSalida.HasValue 
            ? item.HoraSalida.Value.ToString(@"hh\:mm") 
            : "--")
    </td>

    <td>
        <span class="estado-badge 
            @(item.Estado == "Finalizada" 
                ? "estado-finalizada" 
                : item.Estado == "Cancelada" 
                    ? "estado-cancelada" 
                    : "estado-inactivo")">
            @item.Estado
        </span>
    </td>
</tr>
                                    }
                                    
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="empty-state">No hay reservas registradas hoy.</div>
                        }
                    </div>
                </article>

                <article class="panel-card table-card">
                    <h2>Historial de la semana</h2>
                    <div class="mb-3">
    <input type="text" class="form-control"
           placeholder="🔍 Buscar por placa o cliente..."
           onkeyup="filtrarTabla('tablaSemana', this.value)">
</div>
                    <div class="table-wrap">
                        @if (Model.HistorialSemana.Any())
                        {
                            <table class="employee-table" id="tablaSemana">
                                <thead>
                                    <tr>
                                        <th>Código</th>
                                        <th>Cliente</th>
                                        <th>Placa</th>
                                        <th>Fecha</th>
                                        <th>Hora entrada</th>
                                        <th>Hora salida</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.HistorialSemana)
                                    {
                                        <tr>
                                            <td>@item.CodigoReserva</td>
                                            <td>@item.Cliente</td>
                                            <td>@item.Placa</td>
                                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                           <td>@(item.HoraEntrada.HasValue ? item.HoraEntrada.Value.ToString(@"hh\:mm") : "--")</td>
                                           <td>@(item.HoraSalida.HasValue ? item.HoraSalida.Value.ToString(@"hh\:mm") : "--")</td>
                                            <td>
    <span class="estado-badge 
        @(item.Estado == "Finalizada" 
            ? "estado-finalizada" 
            : item.Estado == "Cancelada" 
                ? "estado-cancelada" 
                : "estado-inactivo")">
        @item.Estado
    </span>
</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="empty-state">No hay reservas registradas esta semana.</div>
                        }
                    </div>
                </article>

                <article class="panel-card table-card">
                    <h2>Historial del mes</h2>
                    <div class="mb-3">
    <input type="text" class="form-control"
           placeholder="🔍 Buscar por placa o cliente..."
           onkeyup="filtrarTabla('tablaMes', this.value)">
</div>
                    <div class="table-wrap">
                        @if (Model.HistorialMes.Any())
                        {
                            <table class="employee-table" id="tablaMes">
                                <thead>
                                    <tr>
                                        <th>Código</th>
                                        <th>Cliente</th>
                                        <th>Placa</th>
                                        <th>Fecha</th>
                                        <th>Hora entrada</th>
                                        <th>Hora salida</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.HistorialMes)
                                    {
                                        <tr>
                                            <td>@item.CodigoReserva</td>
                                            <td>@item.Cliente</td>
                                            <td>@item.Placa</td>
                                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                           <td>@(item.HoraEntrada.HasValue ? item.HoraEntrada.Value.ToString(@"hh\:mm") : "--")</td>
                                            <td>@(item.HoraSalida.HasValue ? item.HoraSalida.Value.ToString(@"hh\:mm") : "--")</td>
                                            <td>
    <span class="estado-badge 
        @(item.Estado == "Finalizada" 
            ? "estado-finalizada" 
            : item.Estado == "Cancelada" 
                ? "estado-cancelada" 
                : "estado-inactivo")">
        @item.Estado
    </span>
</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="empty-state">No hay reservas registradas este mes.</div>
                        }
                    </div>
                </article>
            </section>
        </main>
    </div>
    <div class="modal fade" id="modalFinalizar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Finalizar Reserva</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="/Empleado/FinalizarReserva">
                <div class="modal-body">

                    <input type="hidden" id="reservaId" name="id" />
<div class="mb-3 row">
    <div class="col">
        <label>Hora reservada</label>
        <input type="text" id="horaReservada" class="form-control" readonly />
    </div>
    <div class="col">
        <label>Fecha reservada</label>
        <input type="text" id="fechaReservadaDisplay" class="form-control" readonly />
    </div>
</div>

<div class="mb-3">
            <label>Hora entrada</label>
            <input type="time" id="horaEntrada" name="horaEntrada" class="form-control" required />
        </div>
                    <div class="mb-3 row">
    <div class="col">
        <label>Hora salida</label>
        <input type="time" id="horaSalidaDisplay" class="form-control" readonly />
        <input type="hidden" id="horaSalida" name="horaSalida" />
    </div>
    <div class="col">
        <label>Días transcurridos</label>
        <input type="text" id="dias" class="form-control" readonly value="0" />
    </div>
</div>
                    <div class="mb-3">
                        <label>Monto calculado</label>
                        <input type="text" id="monto" class="form-control" readonly />
                    </div>
        

                </div>

               <div class="modal-footer d-flex">
    <button type="button" class="btn btn-modal-footer me-auto" onclick="guardarHoraEntrada()">
        Guardar entrada
    </button>

    <button type="submit" class="btn btn-modal-footer ms-auto">
        Completar
    </button>
</div>

            </form>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
let tarifaHoraGlobal = 0;
let intervaloSalida = null;


function calcularDias() {
    let fechaReservaInput = document.getElementById("fechaReservada");

    if (!fechaReservaInput || !fechaReservaInput.value) return;

    let fechaReserva = new Date(fechaReservaInput.value);
    let ahora = new Date();

    let diferencia = (ahora - fechaReserva) / (1000 * 60 * 60 * 24);
    let dias = Math.floor(diferencia);

    if (dias < 0) dias = 0;

    document.getElementById("dias").value = dias;
}

function abrirModalFinalizar(id, horaReservada, horaEntrada, tarifa, fechaReserva) {
    document.getElementById("reservaId").value = id;

    // Hora reservada
    document.getElementById("horaReservada").value = horaReservada ? horaReservada.substring(0, 5) : "--";

    // Hora de entrada: solo mostrar la guardada para esta reserva
    const horaEntradaInput = document.getElementById("horaEntrada");
    horaEntradaInput.value = horaEntrada ? horaEntrada.substring(0, 5) : "";

    // Fecha reservada
    document.getElementById("fechaReservadaDisplay").value = fechaReserva ?? "";

    // Reiniciar hora de salida y días
    document.getElementById("horaSalidaDisplay").value = "";
    document.getElementById("horaSalida").value = "";
    document.getElementById("dias").value = 0;

    tarifaHoraGlobal = parseFloat(tarifa);

    if (intervaloSalida) clearInterval(intervaloSalida);

    // Actualiza hora de salida y cálculo de días/monto
    intervaloSalida = setInterval(() => {
        const ahora = new Date();
        const horas = String(ahora.getHours()).padStart(2, "0");
        const minutos = String(ahora.getMinutes()).padStart(2, "0");
        const valorHora = `${horas}:${minutos}`;

        document.getElementById("horaSalidaDisplay").value = valorHora;
        document.getElementById("horaSalida").value = valorHora;

        calcularDiasYHoras();
    }, 1000);

    const modal = new bootstrap.Modal(document.getElementById('modalFinalizar'));
    modal.show();
}

// Calcula los días transcurridos desde la fecha de la reserva
// Calcula los días completos y horas desde la hora de entrada
function calcularDiasYHoras() {
    const horaEntradaVal = document.getElementById("horaEntrada").value;
    if (!horaEntradaVal) {
        document.getElementById("dias").value = 0;
        document.getElementById("monto").value = 0;
        return;
    }

    // Hora de entrada como Date
    const ahora = new Date();
    const hoy = new Date();
    const [hEntrada, mEntrada] = horaEntradaVal.split(":");
    const fechaEntrada = new Date(hoy.getFullYear(), hoy.getMonth(), hoy.getDate(), hEntrada, mEntrada, 0, 0);

    // Si la hora de entrada es mayor que ahora, asumimos que es de ayer
    if (fechaEntrada > ahora) {
        fechaEntrada.setDate(fechaEntrada.getDate() - 1);
    }

    // Diferencia en milisegundos
    const diferenciaMs = ahora - fechaEntrada;

    // Calcular días completos y horas restantes
    const diasCompletos = Math.floor(diferenciaMs / (1000 * 60 * 60 * 24));
    const msRestantes = diferenciaMs % (1000 * 60 * 60 * 24);
    const horasExtras = msRestantes / (1000 * 60 * 60);

    // No permitir negativos
    const dias = Math.max(diasCompletos, 0);

    // Actualizar inputs
    document.getElementById("dias").value = dias;

    // Calcular monto total
    const montoTotal = tarifaHoraGlobal * (dias * 24 + horasExtras);
    document.getElementById("monto").value = Math.floor(montoTotal);
}
// Función que calcula monto dinámicamente
function calcularMonto() {
    let entradaVal = document.getElementById("horaEntrada").value;
    let salidaVal = document.getElementById("horaSalida").value;

    if (!entradaVal || !salidaVal) return;

    // Separar horas y minutos
    let [hEntrada, mEntrada] = entradaVal.split(":");
    let [hSalida, mSalida] = salidaVal.split(":");

    // Crear objetos Date completos
    let fechaEntrada = new Date();
    fechaEntrada.setHours(hEntrada, mEntrada, 0, 0);

    let fechaSalida = new Date();
    fechaSalida.setHours(hSalida, mSalida, 0, 0);

    // Ajuste si la salida es antes de la entrada (siguientes días)
    if (fechaSalida < fechaEntrada) {
        while (fechaSalida < fechaEntrada) {
            fechaSalida.setDate(fechaSalida.getDate() + 1);
        }
    }

    // Diferencia en horas, incluyendo fracciones
    let diferencia = (fechaSalida - fechaEntrada) / (1000 * 60 * 60);
    let monto = diferencia * tarifaHoraGlobal;

    document.getElementById("monto").value = "$ " + monto.toFixed(0);
}
//retroceder 1
function guardarHoraEntrada() {
    let id = document.getElementById("reservaId").value;
    let horaEntrada = document.getElementById("horaEntrada").value;

    if (!horaEntrada) {
        alert("Ingrese la hora de entrada");
        return;
    }

    fetch('/Empleado/GuardarEntrada', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ id: id, horaEntrada: horaEntrada })
    })
    .then(res => res.json())

    .then(data => {
    alert("Hora de entrada guardada correctamente");
    location.reload(); // 🔥 recarga la página y trae la hora desde BD
})

    .catch(() => {
        alert("Error al guardar la hora");
    });
}
// Detener el intervalo al cerrar el modal
document.getElementById('modalFinalizar').addEventListener('hidden.bs.modal', () => {
    if (intervaloSalida) clearInterval(intervaloSalida);
});
</script>
<script>
function filtrarTabla(tablaId, texto) {
    let filtro = texto.toLowerCase();
    let tabla = document.getElementById(tablaId);
    let filas = tabla.getElementsByTagName("tr");

    for (let i = 1; i < filas.length; i++) {
        let celdas = filas[i].getElementsByTagName("td");

        let cliente = celdas[1]?.textContent.toLowerCase() || "";
        let placa = celdas[2]?.textContent.toLowerCase() || "";

        if (cliente.includes(filtro) || placa.includes(filtro)) {
            filas[i].style.display = "";
        } else {
            filas[i].style.display = "none";
        }
    }
}
</script>
</body>
</html>
