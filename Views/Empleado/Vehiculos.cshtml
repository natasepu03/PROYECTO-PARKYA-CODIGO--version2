@model ParkYa.ViewModels.EmpleadoVehiculosViewModel
@{
    ViewData["Title"] = "Vehículos";
    var nombreCompleto = $"{Model.Empleado.nombre} {Model.Empleado.apellido}";
    var inicial = !string.IsNullOrWhiteSpace(Model.Empleado.nombre)
        ? Model.Empleado.nombre.Substring(0, 1).ToUpper()
        : "E";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/CSS/empleado.css">
    <script>
        function actualizarFechaHora() {
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, "0");
            const minutos = String(ahora.getMinutes()).padStart(2, "0");
            const segundos = String(ahora.getSeconds()).padStart(2, "0");

            const reloj = document.getElementById("reloj");
            const fecha = document.getElementById("fecha");

            if (reloj) reloj.textContent = `${horas}:${minutos}:${segundos}`;

            const opcionesFecha = {
                weekday: "long",
                year: "numeric",
                month: "long",
                day: "numeric"
            };

            const fechaTexto = ahora.toLocaleDateString("es-ES", opcionesFecha);
            const fechaCap = fechaTexto.charAt(0).toUpperCase() + fechaTexto.slice(1);

            if (fecha) fecha.textContent = fechaCap;
        }

        setInterval(actualizarFechaHora, 1000);
        document.addEventListener("DOMContentLoaded", actualizarFechaHora);
    </script>
</head>
<body>
    <div class="layout">
        <aside class="sidebar">
            <div class="side-brand">
                <img src="~/assets/logo1.jpeg" class="side-logo" alt="logo">
                <div class="brand-text">
                    <h2>ParkYa</h2>
                    <span>Empleado</span>
                </div>
            </div>

            <div class="side-user">
                <div class="avatar">@inicial</div>
                <div class="side-user-info">
                    <h3>@nombreCompleto</h3>
                    <p>@Model.Empleado.correo</p>
                </div>
            </div>

            <nav class="menu">
                <a class="item" href="@Url.Action("Index", "Empleado")">🏠 Inicio</a>
                <a class="item active" href="@Url.Action("Vehiculos", "Empleado")">🚗 Vehículos</a>
                <a class="item" href="@Url.Action("Reservas", "Empleado")">📅 Reservas</a>
            </nav>
        </aside>

        <main class="main-wrapper">
            <header class="top-panel">
                <div class="top-panel-left">
                    <h1>Vehículos</h1>
                    <p>Control actual e historial del día</p>
                </div>

                <div class="top-panel-right">
                    <div class="top-info">
                        <span class="date" id="fecha"></span>
                        <span class="time" id="reloj">00:00:00</span>
                    </div>

                    <div class="top-actions">
                        <button class="btn-pill btn-danger-custom"
                                onclick="location.href='@Url.Action("Login","Autenticacion")'">
                            Cerrar sesión
                        </button>
                    </div>
                </div>
            </header>

            <section class="dashboard-grid">
                <article class="panel-card">
                    <h2>Resumen</h2>
                    <p class="sub">Estado actual de vehículos</p>

                    <div class="summary-stats">
                        <div class="stat-mini">
                            <span>Dentro del parqueadero</span>
                            <strong>@Model.TotalDentro</strong>
                        </div>
                        <div class="stat-mini">
                            <span>Salidos hoy</span>
                            <strong>@Model.TotalSalidosHoy</strong>
                        </div>
                    </div>
                </article>

                <article class="panel-card table-card">
                    <h2>Vehículos dentro del parqueadero</h2>
                    <p class="sub">Reservas activas en este momento</p>

                    <div class="table-wrap">
                        @if (Model.VehiculosDentro.Any())
                        {
                            <table class="employee-table">
                                <thead>
                                    <tr>
                                        <th>Placa</th>
                                        <th>Marca</th>
                                        <th>Color</th>
                                        <th>Propietario</th>
                                        <th>Fecha</th>
                                        <th>Hora entrada</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.VehiculosDentro)
                                    {
                                        <tr>
                                            <td>@item.Placa</td>
                                            <td>@item.Marca</td>
                                            <td>@item.Color</td>
                                            <td>@item.Propietario</td>
                                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                            <td>@item.HoraEntrada.ToString(@"hh\:mm")</td>
                                            <td>
                                                <span class="estado-badge estado-activo">@item.Estado</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="empty-state">No hay vehículos dentro del parqueadero en este momento.</div>
                        }
                    </div>
                </article>

                <article class="panel-card table-card">
                    <h2>Historial del día</h2>
                    <p class="sub">Vehículos que ya no están activos hoy</p>

                    <div class="table-wrap">
                        @if (Model.HistorialSalidasHoy.Any())
                        {
                            <table class="employee-table">
                                <thead>
                                    <tr>
                                        <th>Placa</th>
                                        <th>Marca</th>
                                        <th>Color</th>
                                        <th>Propietario</th>
                                        <th>Fecha</th>
                                        <th>Hora entrada</th>
                                        <th>Hora salida</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.HistorialSalidasHoy)
                                    {
                                        <tr>
                                            <td>@item.Placa</td>
                                            <td>@item.Marca</td>
                                            <td>@item.Color</td>
                                            <td>@item.Propietario</td>
                                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                            <td>@item.HoraEntrada.ToString(@"hh\:mm")</td>
                                            <td>@item.HoraSalida.ToString(@"hh\:mm")</td>
                                            <td>
                                                <span class="estado-badge estado-inactivo">@item.Estado</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="empty-state">No hay historial de vehículos para hoy.</div>
                        }
                    </div>
                </article>
            </section>
        </main>
    </div>
</body>
</html>