@model ParkYa.ViewModels.EmpleadoReportesViewModel
@{
    ViewData["Title"] = "Reportes";
    var nombreCompleto = $"{Model.Empleado.nombre} {Model.Empleado.apellido}";
    var inicial = !string.IsNullOrWhiteSpace(Model.Empleado.nombre)
        ? Model.Empleado.nombre.Substring(0, 1).ToUpper()
        : "E";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/CSS/empleado.css">
    <script>
        function actualizarFechaHora() {
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, "0");
            const minutos = String(ahora.getMinutes()).padStart(2, "0");
            const segundos = String(ahora.getSeconds()).padStart(2, "0");

            const reloj = document.getElementById("reloj");
            const fecha = document.getElementById("fecha");

            if (reloj) reloj.textContent = `${horas}:${minutos}:${segundos}`;

            const opcionesFecha = {
                weekday: "long",
                year: "numeric",
                month: "long",
                day: "numeric"
            };

            const fechaTexto = ahora.toLocaleDateString("es-ES", opcionesFecha);
            const fechaCap = fechaTexto.charAt(0).toUpperCase() + fechaTexto.slice(1);

            if (fecha) fecha.textContent = fechaCap;
        }

        setInterval(actualizarFechaHora, 1000);
        document.addEventListener("DOMContentLoaded", actualizarFechaHora);
    </script>
</head>
<body>
    <div class="layout">
        <aside class="sidebar">
            <div class="side-brand">
                <img src="~/assets/logo1.jpeg" class="side-logo" alt="logo">
                <div class="brand-text">
                    <h2>ParkYa</h2>
                    <span>Empleado</span>
                </div>
            </div>

            <div class="side-user">
                <div class="avatar">@inicial</div>
                <div class="side-user-info">
                    <h3>@nombreCompleto</h3>
                    <p>@Model.Empleado.correo</p>
                </div>
            </div>

            <nav class="menu">
                <a class="item" href="@Url.Action("Index", "Empleado")">🏠 Inicio</a>
                <a class="item active" href="@Url.Action("Reportes", "Empleado")">📊 Reportes</a>
                <a class="item" href="@Url.Action("Reservas", "Empleado")">📅 Reservas</a>
            </nav>
        </aside>

        <main class="main-wrapper">
            <header class="top-panel">
                <div class="top-panel-left">
                  <h1>Reportes</h1>
<p>Historial y reportes de reservas</p>
                </div>

                <div class="top-panel-right">
                    <div class="top-info">
                        <span class="date" id="fecha"></span>
                        <span class="time" id="reloj">00:00:00</span>
                    </div>

                    <div class="top-actions">
                        <button class="btn-pill btn-danger-custom"
                                onclick="location.href='@Url.Action("Login","Autenticacion")'">
                            Cerrar sesión
                        </button>
                    </div>
                </div>
            </header>

            <section class="dashboard-grid">
                <article class="panel-card">
    <h2>Resumen de reportes</h2>
    <p class="sub">Cantidad de reservas registradas</p>

    <div class="summary-stats">
        <div class="stat-mini">
            <span>Reservas hoy</span>
            <strong>@Model.TotalReservasHoy</strong>
        </div>
        <div class="stat-mini">
            <span>Reservas semana</span>
            <strong>@Model.TotalReservasSemana</strong>
        </div>
        <div class="stat-mini">
            <span>Reservas mes</span>
            <strong>@Model.TotalReservasMes</strong>
        </div>
    </div>
</article>
            <article class="panel-card table-card">
    <h2>Historial del día</h2>
    <button class="btn btn-primary mb-3">Generar Reporte de Hoy</button>

    <div class="table-wrap">
        @if (Model.HistorialHoy.Any())
        {
            <table class="employee-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Placa</th>
                        <th>Fecha</th>
                        <th>Entrada</th>
                        <th>Salida</th>
                        <th>Estado</th>
                        <th>Reporte</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.HistorialHoy)
                    {
                        <tr>
                            <td>@item.IdReserva</td>
                            <td>@item.Cliente</td>
                            <td>@item.Placa</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@(item.HoraEntrada?.ToString(@"hh\:mm") ?? "--")</td>
                            <td>@(item.HoraSalida?.ToString(@"hh\:mm") ?? "--")</td>
                            <td>@item.Estado</td>
                            <td>
                                <button class="btn btn-sm btn-secondary"
                                        onclick="location.href='@Url.Action("ReporteReserva","Reportes", new { id = item.IdReserva })'">
                                    📝
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">No hay reservas hoy.</div>
        }
    </div>
</article>
<article class="panel-card table-card">
    <h2>Historial de la semana</h2>
<button class="btn btn-warning mb-3">Generar Reporte de la Semana</button>
    <div class="table-wrap">
        @if (Model.HistorialSemana.Any())
        {
            <table class="employee-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Placa</th>
                        <th>Fecha</th>
                        <th>Entrada</th>
                        <th>Salida</th>
                        <th>Estado</th>
                        <th>Reporte</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.HistorialSemana)
                    {
                        <tr>
                            <td>@item.IdReserva</td>
                            <td>@item.Cliente</td>
                            <td>@item.Placa</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@(item.HoraEntrada?.ToString(@"hh\:mm") ?? "--")</td>
                            <td>@(item.HoraSalida?.ToString(@"hh\:mm") ?? "--")</td>
                            <td>@item.Estado</td>
                            <td>
                                <button class="btn btn-sm btn-secondary"
                                        onclick="location.href='@Url.Action("ReporteReserva","Reportes", new { id = item.IdReserva })'">
                                    📝
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">No hay reservas esta semana.</div>
        }
    </div>
</article>
<article class="panel-card table-card">
    <h2>Historial del mes</h2>
    <button class="btn btn-success mb-3">Generar Reporte del Mes</button>

    <div class="table-wrap">
        @if (Model.HistorialMes.Any())
        {
            <table class="employee-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Placa</th>
                        <th>Fecha</th>
                        <th>Entrada</th>
                        <th>Salida</th>
                        <th>Estado</th>
                        <th>Reporte</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.HistorialMes)
                    {
                        <tr>
                            <td>@item.IdReserva</td>
                            <td>@item.Cliente</td>
                            <td>@item.Placa</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@(item.HoraEntrada?.ToString(@"hh\:mm") ?? "--")</td>
                            <td>@(item.HoraSalida?.ToString(@"hh\:mm") ?? "--")</td>
                            <td>@item.Estado</td>
                            <td>
                                <button class="btn btn-sm btn-secondary"
                                        onclick="location.href='@Url.Action("ReporteReserva","Reportes", new { id = item.IdReserva })'">
                                    📝
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">No hay reservas este mes.</div>
        }
    </div>
</article>    
            
                
            </section>
        </main>
    </div>
</body>
</html>
