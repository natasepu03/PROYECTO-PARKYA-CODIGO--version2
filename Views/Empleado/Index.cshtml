@model ParkYa.ViewModels.DashboardEmpleadoViewModel
@{
    ViewData["Title"] = "Dashboard Empleado";
    var nombreCompleto = $"{Model.Empleado.nombre} {Model.Empleado.apellido}";
    var inicial = !string.IsNullOrWhiteSpace(Model.Empleado.nombre)
        ? Model.Empleado.nombre.Substring(0, 1).ToUpper()
        : "E";
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/empleado.css">

        <script>
                function actualizarFechaHora() {
                    const ahora = new Date();

                    const horas = String(ahora.getHours()).padStart(2, "0");
                    const minutos = String(ahora.getMinutes()).padStart(2, "0");
                    const segundos = String(ahora.getSeconds()).padStart(2, "0");

                    const reloj = document.getElementById("reloj");
                    const fecha = document.getElementById("fecha");

                    if (reloj) {
                        reloj.textContent = `${horas}:${minutos}:${segundos}`;
                    }

                    const opcionesFecha = {
                        weekday: "long",
                        year: "numeric",
                        month: "long",
                        day: "numeric"
                    };

                    const fechaTexto = ahora.toLocaleDateString("es-ES", opcionesFecha);
                    const fechaCap = fechaTexto.charAt(0).toUpperCase() + fechaTexto.slice(1);

                    if (fecha) {
                        fecha.textContent = fechaCap;
                    }
                }

                setInterval(actualizarFechaHora, 1000);
                document.addEventListener("DOMContentLoaded", actualizarFechaHora);
        </script>
    </head>

    <body>
        <div class="layout">

            <aside class="sidebar">
                <div class="side-brand">
                    <img src="~/assets/logo1.jpeg" class="side-logo" alt="logo">
                        <div class="brand-text">
                            <h2>ParkYa</h2>
                            <span>Empleado</span>
                        </div>
                    </div>

                    <div class="side-user">
                        <div class="avatar">@inicial</div>
                        <div class="side-user-info">
                            <h3>@nombreCompleto</h3>
                            <p>@Model.Empleado.correo</p>
                        </div>
                    </div>

                    <nav class="menu">

                        <a class="item" asp-controller="Empleado" asp-action="Index">
                            <i class="bi bi-house-door-fill"></i> Inicio
                        </a>

                        <a class="item" asp-controller="Empleado" asp-action="Reportes">
                            <i class="bi bi-bar-chart-fill"></i> Reportes
                        </a>

                        <a class="item" asp-controller="Empleado" asp-action="Reservas">
                            <i class="bi bi-calendar-check-fill"></i> Reservas
                        </a>

                    </nav>
                </aside>

                <main class="main-wrapper">

                    <header class="top-panel">
                        <div class="top-panel-left">
                            <h1>Bienvenido, @nombreCompleto</h1>
                            <p>Tu panel operativo del parqueadero</p>
                        </div>

                        <div class="top-panel-right">
                            <div class="top-info">
                                <span class="date" id="fecha"></span>
                                <span class="time" id="reloj">00:00:00</span>
                            </div>

                            <div class="top-actions">
                                <button class="btn-pill btn-light-custom d-lg-none" data-bs-toggle="offcanvas"
                                        data-bs-target="#sidebarMenu">
                                    Menú
                                </button>

                                <div class="top-actions">
                                    <button type="button" class="btn-pill btn-light-custom" onclick="abrirModalEditarPerfil()">
                                        Editar Perfil
                                    </button>

                                    <button class="btn-pill btn-danger-custom"
                                            onclick="location.href='@Url.Action("Login","Autenticacion")'">
                                        Cerrar sesión
                                    </button>
                                </div>
                            </div>
                        </header>

                        <section class="dashboard-grid">
                            <article class="panel-card">
                                <h2>Perfil rápido</h2>
                                <p class="sub">Información principal del empleado</p>

                                <div class="summary-box">
                                    <p><strong>Nombre:</strong> @nombreCompleto</p>
                                    <p><strong>Correo:</strong> @Model.Empleado.correo</p>
                                    <p><strong>Rol:</strong> Empleado</p>
                                </div>
                            </article>

                            <article class="panel-card">
                                <h2>Resumen del día</h2>
                                <p class="sub">Información general del sistema</p>

                                <div class="summary-stats">
                                    <div class="stat-mini">
                                        <span>Total vehículos</span>
                                        <strong>@Model.TotalVehiculos</strong>
                                    </div>
                                    <div class="stat-mini">
                                        <span>Total reservas</span>
                                        <strong>@Model.TotalReservas</strong>
                                    </div>
                                    <div class="stat-mini">
                                        <span>Reservas activas</span>
                                        <strong>@Model.ReservasActivas</strong>
                                    </div>
                                </div>
                            </article>
                            <article class="panel-card" style="grid-column: 1 / -1;">
                                <h2>Accesos rápidos</h2>
                                <p class="sub">Acciones principales del sistema</p>

                                <div class="quick-actions">
        
                                    <a href="@Url.Action("Reservas", "Empleado")" class="quick-card">
                                        <i class="bi bi-calendar-check"></i>
                                        <span>Gestionar reservas</span>
                                    </a>

                                    <a href="@Url.Action("Reportes", "Empleado")" class="quick-card">
                                        <i class="bi bi-bar-chart"></i>
                                        <span>Ver reportes</span>
                                    </a>

                                    <button onclick="abrirModalEditarPerfil()" class="quick-card">
                                        <i class="bi bi-person-gear"></i>
                                        <span>Editar perfil</span>
                                    </button>

                                </div>
                            </article>

               
                        </section>
                    </main>
                </div>

                <div class="offcanvas offcanvas-start offcanvas-custom" tabindex="-1" id="sidebarMenu">
                    <div class="offcanvas-header">
                        <h5 class="mb-0">Menú empleado</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
                    </div>
                    <div class="offcanvas-body">
                        <div class="side-user">
                            <div class="avatar">@inicial</div>
                            <div class="side-user-info">
                                <h3>@nombreCompleto</h3>
                                <p>@Model.Empleado.correo</p>
                            </div>
                        </div>

                        <nav class="menu">

                        <a class="item" asp-controller="Empleado" asp-action="Index">
                            <i class="bi bi-house-door-fill"></i> Inicio
                        </a>

                        <a class="item" asp-controller="Empleado" asp-action="Reportes">
                            <i class="bi bi-bar-chart-fill"></i> Reportes
                        </a>

                        <a class="item" asp-controller="Empleado" asp-action="Reservas">
                            <i class="bi bi-calendar-check-fill"></i> Reservas
                        </a>

                    </nav>
                    </div>
                </div>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
                @if (TempData["PerfilActualizado"] != null)
                {
                    <script>
                        alert('@TempData["PerfilActualizado"]');
                    </script>
                }

                <div id="modalEditarPerfil" class="modal-overlay-custom">
                    <div class="modal-card-custom">
                        <div class="modal-header-custom">
                            <h2>Editar Perfil</h2>
                            <button type="button" class="modal-close-btn" onclick="cerrarModalEditarPerfil()">×</button>
                        </div>

                        <form method="post" action="@Url.Action("ActualizarPerfilEmpleado", "Empleado")">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id_usuario" value="@Model.Empleado.id_usuario" />

                            <div class="form-group-custom">
                                <label for="nombre">Nombre</label>
                                <input type="text" id="nombre" name="nombre" value="@Model.Empleado.nombre" required />
                            </div>

                            <div class="form-group-custom">
                                <label for="apellido">Apellido</label>
                                <input type="text" id="apellido" name="apellido" value="@Model.Empleado.apellido" required />
                            </div>

                            <div class="form-group-custom">
                                <label for="correo">Correo</label>
                                <input type="email" id="correo" name="correo" value="@Model.Empleado.correo" required />
                            </div>

                            <button type="submit" class="modal-save-btn">
                                Guardar cambios
                            </button>
                        </form>
                    </div>
                </div>

                @if (TempData["PerfilActualizado"] != null)
                {
                    <script>
                        alert('@TempData["PerfilActualizado"]');
                    </script>
                }

                <div id="modalEditarPerfil" class="modal-overlay-custom">
                    <div class="modal-card-custom">
                        <div class="modal-header-custom">
                            <h2>Editar Perfil</h2>
                            <button type="button" class="modal-close-btn" onclick="cerrarModalEditarPerfil()">×</button>
                        </div>

                        <form method="post" action="@Url.Action("ActualizarPerfilEmpleado", "Empleado")">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id_usuario" value="@Model.Empleado.id_usuario" />

                            <div class="form-group-custom">
                                <label for="nombre">Nombre</label>
                                <input type="text" id="nombre" name="nombre" value="@Model.Empleado.nombre" required />
                            </div>

                            <div class="form-group-custom">
                                <label for="apellido">Apellido</label>
                                <input type="text" id="apellido" name="apellido" value="@Model.Empleado.apellido" required />
                            </div>

                            <div class="form-group-custom">
                                <label for="correo">Correo</label>
                                <input type="email" id="correo" name="correo" value="@Model.Empleado.correo" required />
                            </div>

                            <button type="submit" class="modal-save-btn">
                                Guardar cambios
                            </button>
                        </form>
                    </div>
                </div>

                <script>
                    function abrirModalEditarPerfil() {
                    const modal = document.getElementById("modalEditarPerfil");
                    if (modal) {
                    modal.classList.add("show");
                    }
                    }

                    function cerrarModalEditarPerfil() {
                    const modal = document.getElementById("modalEditarPerfil");
                    if (modal) {
                    modal.classList.remove("show");
                    }
                    }

                    document.addEventListener("click", function (e) {
                    const modal = document.getElementById("modalEditarPerfil");
                    if (e.target === modal) {
                    cerrarModalEditarPerfil();
                    }
                    });
                </script>
            </body>

        </html>
