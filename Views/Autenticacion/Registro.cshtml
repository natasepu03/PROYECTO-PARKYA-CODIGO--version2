@model ParkYa.Models.ViewModels.RegistroViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro - ParkYa</title>
    <link rel="stylesheet" href="/css/registro.css?v=9999">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<body>

    <div class="d-flex justify-content-center align-items-center min-vh-100">

        <div class="registro-container col-11 col-sm-10 col-md-8 col-lg-6">

            <button type="button" class="btn-volver" onclick="location.href='@Url.Action("Index","Home")'">←
                Volver</button>

                <img src="~/assets/logo1.jpeg" class="logo">

                    <h1>Registro de Nuevo Cliente</h1>
                    <p class="sub">Completa tus datos para crear tu cuenta en PARKYA</p>

                    <form id="formRegistro" asp-controller="Autenticacion" asp-action="Registro" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-grid">

                            <div>
                                <label for="fullName">Nombre</label>
                                <input asp-for="nombre" type="text" id="fullName" placeholder="Ej: María" required
                                       pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ\s]+" minlength="3">
                                </div>

                                <div>
                                    <label for="lastName">Apellido</label>
                                    <input asp-for="apellido" type="text" id="lastName" placeholder="Ej: Gómez" required
                                           pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ\s]+" minlength="3">
                                    </div>

                                    <div>
                                        <label for="doctype">Tipo de documento</label>
                                        <select asp-for="tipo_doc" id="doctype" required>
                                            <option selected disabled>Selecciona tipo</option>
                                            <option value="CC">Cédula de Ciudadanía</option>
                                            <option value="TI">Tarjeta de Identidad</option>
                                            <option value="CE">Cédula Extranjera</option>
                                        </select>
                                    </div>

                                    <div>
                                        <label for="document">Número de documento</label>
                                        <input asp-for="documento" type="text" id="document" placeholder="Ej: 1140917448" required
                                               minlength="7" pattern="[0-9]+">
                                        </div>

                                        <div>
                                            <label for="email">Correo electrónico</label>
                                            <input asp-for="correo" type="email" id="email" placeholder="correo@example.com" required>
                                            </div>

                                            <div>
                                                <label for="phone">Teléfono</label>
                                                <input asp-for="telefono" type="text" id="phone" placeholder="Ej: 3174567592" required
                                                       minlength="7" pattern="[0-9]+">
                                                </div>

                                                <!-- CONTRASEÑA -->
                                                <div>
                                                    <label for="password">Contraseña</label>

                                                    <div class="password-container">
                                                        <input asp-for="contraseña" type="password" id="password" class="form-control"
                                                               placeholder="Crea una contraseña segura" required />

                                                        <svg id="togglePass1" class="icon-eye" viewBox="0 0 24 24">
                                                            <path
                                                            d="M12 5C7 5 2.73 8.11 1 12c1.73 3.89 6 7 11 7s9.27-3.11 11-7c-1.73-3.89-6-7-11-7z"
                                                            stroke="currentColor" stroke-width="2" fill="none" />
                                                            <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2" fill="none" />
                                                        </svg>
                                                    </div>

                                                    <span asp-validation-for="contraseña" class="text-danger"></span>
                                                </div>

                                                <!-- CONFIRMAR CONTRASEÑA -->
                                                <div>
                                                    <label for="confirmPassword">Confirmar contraseña</label>

                                                    <div class="password-container">
                                                        <input asp-for="confirmarContraseña" type="password" id="confirmPassword"
                                                               class="form-control" placeholder="Repite la contraseña" required />

                                                        <svg id="togglePass2" class="icon-eye" viewBox="0 0 24 24">
                                                            <path
                                                            d="M12 5C7 5 2.73 8.11 1 12c1.73 3.89 6 7 11 7s9.27-3.11 11-7c-1.73-3.89-6-7-11-7z"
                                                            stroke="currentColor" stroke-width="2" fill="none" />
                                                            <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2" fill="none" />
                                                        </svg>
                                                    </div>
                                                    <span asp-validation-for="confirmarContraseña" class="text-danger"></span>
                                                </div>

                                                <div class="password-help-container">
                                                        <div class="password-box">
                                                            <i class="bi bi-shield-lock"></i>
                                                            <span>Mínimo 8 caracteres, con mayúscula, minúscula, número y símbolo especial.</span>
                                                        </div>
                                                </div>

                                                <div>
                                                    <label asp-for="PreguntaSeguridad">Pregunta de seguridad</label>
                                                    <select asp-for="PreguntaSeguridad" required>
                                                        <option selected disabled value="">Selecciona una pregunta</option>
                                                        <option value="¿Nombre de tu primera mascota?">¿Nombre de tu primera mascota?</option>
                                                        <option value="¿Ciudad donde naciste?">¿Ciudad donde naciste?</option>
                                                        <option value="¿Nombre de tu escuela primaria?">¿Nombre de tu escuela primaria?</option>
                                                        <option value="¿Comida favorita?">¿Comida favorita?</option>
                                                    </select>
                                                    <span asp-validation-for="PreguntaSeguridad" class="text-danger"></span>
                                                </div>

                                                <div>
                                                    <label asp-for="RespuestaSeguridad">Respuesta de seguridad</label>
                                                    <input asp-for="RespuestaSeguridad" type="text" placeholder="Escribe tu respuesta" required>
                                                        <span asp-validation-for="RespuestaSeguridad" class="text-danger"></span>
                                                    </div>

                                                    <button class="btn-submit" type="submit">Crear Cuenta</button>

                                                    <p class="tienes-cuenta">
                                                        ¿Ya tienes cuenta?
                                                        <a asp-controller="Autenticacion" asp-action="Login">Inicia sesión</a>
                                                    </p>

                                                </div>
                                            </form>

                                        </div>
                                    </div>
                                    <script>
                                            // CONTRASEÑA
                                            const togglePass1 = document.getElementById("togglePass1");
                                            const password = document.getElementById("password");

                                            togglePass1.addEventListener("click", () => {
                                                const type = password.type === "password" ? "text" : "password";
                                                password.type = type;
                                            });

                                            // CONFIRMAR CONTRASEÑA
                                            const togglePass2 = document.getElementById("togglePass2");
                                            const confirmPassword = document.getElementById("confirmPassword");

                                            togglePass2.addEventListener("click", () => {
                                                const type = confirmPassword.type === "password" ? "text" : "password";
                                                confirmPassword.type = type;
                                            });
                                    </script>
                                </body>

                            </html>


