@model ParkYa.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inicia sesión</title>
    <link rel="stylesheet" href="/css/login.css?v=9999" >
    
</head>
<body>
    <div class="registro-container">
        <button class="btn-volver" onclick="location.href='@Url.Action("Index","Home")'">← Volver</button>

        <img src="~/assets/logo1.jpeg" class="logo" alt="Logo">

        <h1>Bienvenido de nuevo</h1>
        <p class="sub">Completa tus datos para ingresar PARKYA</p>

        <form asp-controller="Autenticacion" asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-grid">
                <label asp-for="Correo"></label>
                <input asp-for="Correo" class="form-control" placeholder="correo@example.com" />
                <span asp-validation-for="Correo" class="text-danger"></span>

                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Escribe tu contraseña" />
                <span asp-validation-for="Password" class="text-danger"></span>

                <button class="btn-submit" type="submit">Iniciar sesión</button>
            </div>
        </form>

        <div class="mt-3 text-center">
            <a asp-controller="Autenticacion" asp-action="Recuperacion">¿Olvidaste tu contraseña?</a>
        </div>
    </div>
</body>
</html>