@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Contraseña - ParkYa</title>

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="@Url.Content("~/css/recuperacionC.css")">
</head>
<body>

<div class="container d-flex justify-content-center align-items-center min-vh-100">

    <div class="form-box col-11 col-sm-9 col-md-6 col-lg-4">

        <img src="@Url.Content("~/assets/logo1.jpeg")" class="logo" alt="Logo ParkYa">

        <h2>¿Olvidaste tu contraseña?</h2>

        <p class="descripcion">
            Ingresa tu correo registrado y te enviaremos un enlace para restablecerla.
        </p>

        <form action="#" method="POST">

            <div class="mb-3 text-start">
                <label for="correo" class="form-label fw-bold">Correo electrónico</label>
                <input type="email" id="correo" name="correo" required placeholder="ejemplo@correo.com" class="form-control">
            </div>

            <button type="submit" class="btn-enviar w-100">Enviar enlace</button>

            <div class="text-center mt-2">
                <a href="@Url.Content("~/login.html")" class="volver">← Volver al inicio de sesión</a>
            </div>

        </form>

    </div>

</div>

</body>
</html>
