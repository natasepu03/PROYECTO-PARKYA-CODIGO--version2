                        <p class="sub">COP</p>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card p-3 h-100">
                        <p class="title">Reservas</p>
                        <h1>3</h1>
                        <p class="sub">activas</p>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card p-3 h-100">
                        <p class="title">Tiempo Promedio</p>
                        <h1>2h 30m</h1>
                        <p class="sub">de estancia</p>
                    </div>
