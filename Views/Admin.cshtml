                        <p class="sub">trabajando hoy</p>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card p-3 h-100">
                        <p class="title">Total Semanal</p>
                        <h1>$1595K</h1>
