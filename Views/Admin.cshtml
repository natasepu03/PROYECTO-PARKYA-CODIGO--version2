@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PARKYA Dashboard</title>

    <!-- BOOTSTRAP CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome (ya usado por tu UI) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <!-- TU CSS (reemplaza /vista/css/admin.css por el que te doy abajo) -->
    <link rel="stylesheet" href="/ParkYa/wwwroot/css/admin.css">

</head>
<body>
<!-- ===== TOPBAR (hamburger left) ===== -->
<nav class="navbar navbar-light bg-white shadow-sm px-3 topbar">
    <div class="d-flex align-items-center">
        <!-- HAMBURGER (muestra offcanvas en mobile) -->
        <button class="btn btn-outline-primary me-3 d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasSidebar" aria-controls="offcanvasSidebar" aria-label="Abrir menú">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Logo pequeño (opcional en topbar) -->
        <img src="/ParkYa/wwwroot/assets/logo1.jpeg" class="d-none d-md-inline-block logo-img me-3" alt="logo">

        <!-- Search -->
        <input class="form-control search d-none d-md-block" type="search" placeholder="Buscar placa…" aria-label="Buscar">
    </div>

    <div class="d-flex align-items-center gap-3">
        <div class="top-info text-end me-2 d-none d-md-block">
            <div class="date" id="fecha"></div>
            <div class="time" id="reloj">00:00:00</div>
        </div>

        <i class="fa-regular fa-circle-question icon d-none d-md-inline"></i>

        <div class="notif position-relative d-none d-md-inline-block">
            <i class="fa-regular fa-bell fs-5"></i>
            <span class="badge">3</span>
        </div>

        <div class="profile d-flex align-items-center">
            <div class="circle">CR</div>
            <div class="profile-text d-none d-md-flex flex-column ms-2">
                <p class="name mb-0">Carlos Rodríguez</p>
                <small class="profile-role">Administrador</small>
            </div>
            <button class="btn-salir ms-3">Salir</button>
        </div>
    </div>
</nav>

<!-- ===== OFFCANVAS SIDEBAR (mobile) ===== -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasSidebar" aria-labelledby="offcanvasSidebarLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="offcanvasSidebarLabel">PARKYA</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
    </div>
    <div class="offcanvas-body p-0">
        <!-- Reutilizamos la estructura de tu sidebar dentro del offcanvas -->
        <aside class="sidebar-mobile p-3">
            <div class="logo text-center mb-2">
                <img src="/ParkYa/wwwroot/assets/logo1.jpeg" alt="Logo" class="logo-img">
            </div>

            <div class="user-info text-center mb-3">
                <h3 class="h6 mb-1">Carlos Rodríguez</h3>
                <span class="role">Administrador</span>
            </div>

            <div class="state-box mb-3">
                <p class="mb-1"><span class="dot"></span> Disponible</p>
                <p class="label mb-2">Ocupación</p>
                <div class="progress">
                    <div class="progress-bar" style="width: 28%"></div>
                </div>
                <small>28%</small>
            </div>

            <nav class="menu d-flex flex-column gap-1">
                <a href="#" class="active p-2 rounded"><i class="fa-solid fa-table-columns me-2"></i> Dashboard</a>
                <a href="#" class="p-2 rounded"><i class="fa-solid fa-car me-2"></i> Vehículos</a>
                <a href="#" class="p-2 rounded"><i class="fa-regular fa-calendar me-2"></i> Reservas</a>
                <a href="#" class="p-2 rounded"><i class="fa-regular fa-user me-2"></i> Clientes</a>
                <a href="#" class="p-2 rounded"><i class="fa-solid fa-users me-2"></i> Empleados</a>
                <a href="#" class="p-2 rounded"><i class="fa-solid fa-chart-line me-2"></i> Reportes</a>
                <a href="#" class="p-2 rounded"><i class="fa-solid fa-tags me-2"></i> Tarifas</a>
                <a href="#" class="p-2 rounded"><i class="fa-solid fa-gear me-2"></i> Configuración</a>
            </nav>

            <footer class="footer mt-auto text-center small">PARKYA © 2025</footer>
        </aside>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <!-- ===== SIDEBAR FIJO (desktop) ===== -->
        <aside class="col-md-3 col-lg-2 d-none d-md-flex flex-column sidebar">
            <div class="logo text-center mb-3">
