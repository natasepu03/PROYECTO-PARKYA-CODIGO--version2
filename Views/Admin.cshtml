            </div>

            <div class="state-box mb-3">
                <p class="mb-1"><span class="dot"></span> Disponible</p>
                <p class="label mb-2">Ocupación</p>
                <div class="progress">
                    <div class="progress-bar" style="width: 28%"></div>
                </div>
                <small>28%</small>
            </div>

            <nav class="menu d-flex flex-column gap-1">
                <a href="#" class="active p-2 rounded"><i class="fa-solid fa-table-columns me-2"></i> Dashboard</a>
                <a href="#" class="p-2 rounded"><i class="fa-solid fa-car me-2"></i> Vehículos</a>
                <a href="#" class="p-2 rounded"><i class="fa-regular fa-calendar me-2"></i> Reservas</a>
                <a href="#" class="p-2 rounded"><i class="fa-regular fa-user me-2"></i> Clientes</a>
                <a href="#" class="p-2 rounded"><i class="fa-solid fa-users me-2"></i> Empleados</a>
                <a href="#" class="p-2 rounded"><i class="fa-solid fa-chart-line me-2"></i> Reportes</a>
                <a href="#" class="p-2 rounded"><i class="fa-solid fa-tags me-2"></i> Tarifas</a>
