@model ParkYa.ViewModels.AdministradorReservasViewModel
@{
    ViewData["Title"] = "Reservas";
    var nombreCompleto = $"{Model.Administrador.nombre} {Model.Administrador.apellido}";
    var inicial = !string.IsNullOrWhiteSpace(Model.Administrador.nombre)
        ? Model.Administrador.nombre.Substring(0, 1).ToUpper()
        : "E";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css">
    <script>
        function actualizarFechaHora() {
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, "0");
            const minutos = String(ahora.getMinutes()).padStart(2, "0");
            const segundos = String(ahora.getSeconds()).padStart(2, "0");
            const reloj = document.getElementById("reloj");
            const fecha = document.getElementById("fecha");

            if (reloj) {
                reloj.textContent = `${horas}:${minutos}:${segundos}`;
            }

            const opcionesFecha = {
                weekday: "long",
                year: "numeric",
                month: "long",
                day: "numeric"
            };

            const fechaTexto = ahora.toLocaleDateString("es-ES", opcionesFecha);
            if (fecha) {
                fecha.textContent = fechaTexto.charAt(0).toUpperCase() + fechaTexto.slice(1);
            }
        }

        setInterval(actualizarFechaHora, 1000);
        document.addEventListener("DOMContentLoaded", actualizarFechaHora);
    </script>
</head>
<body>
    <div class="layout">
        <aside class="sidebar">
            <div class="side-brand">
                <img src="~/assets/logo1.jpeg" class="side-logo" alt="logo">
                <div class="brand-text">
                    <h2>ParkYa</h2>
                    <span>Administrador</span>
                </div>
            </div>

            <div class="side-user">
                <div class="avatar">@inicial</div>
                <div class="side-user-info">
                    <h3>@nombreCompleto</h3>
                    <p>@Model.Administrador.correo</p>
                </div>
            </div>

            <nav class="menu">
                <a class="item" asp-controller="Administrador" asp-action="Index">🏠 Inicio</a>
                <a class="item" asp-controller="Administrador" asp-action="Usuarios">👤 Usuarios</a>
                <a class="item" asp-controller="Administrador" asp-action="Tarifas">🏷️Tarifas</a>
                <a class="item" asp-controller="Administrador" asp-action="Reservas">📅Reservas</a>
                 <a class="item" asp-controller="Administrador" asp-action="Reportes">📊Reportes</a>
            </nav>
        </aside>

        <main class="main-wrapper">
            <header class="top-panel">
                <div class="top-panel-left">
                    <h1>Reservas</h1>
                    <p>Control general de reservas del sistema</p>
                </div>

                <div class="top-panel-right">
                    <div class="top-info">
                        <span class="date" id="fecha"></span>
                        <span class="time" id="reloj">00:00:00</span>
                    </div>

                    <div class="top-actions">
                        <button class="btn-pill btn-danger-custom"
                                onclick="location.href='@Url.Action("Login","Autenticacion")'">
                            Cerrar sesion
                        </button>
                    </div>
                </div>
            </header>

            <section class="dashboard-grid">
                <article class="panel-card">
                    <h2>Resumen</h2>
                    <p class="sub">Estado general de las reservas</p>

                    <div class="summary-stats">
                        <div class="stat-mini">
                            <span>Total</span>
                            <strong>@Model.TotalReservas</strong>
                        </div>
                        <div class="stat-mini">
                            <span>Pendientes</span>
                            <strong>@Model.ReservasPendientes</strong>
                        </div>
                        <div class="stat-mini">
                            <span>Finalizadas</span>
                            <strong>@Model.ReservasFinalizadas</strong>
                        </div>
                        <div class="stat-mini">
                            <span>Canceladas</span>
                            <strong>@Model.ReservasCanceladas</strong>
                        </div>
                    </div>
                </article>

                <article class="panel-card table-card panel-full">
                    <h2>Reservas registradas</h2>
                    <p class="sub">Misma informacion base del modulo de empleado, con monto agregado.</p>

                    <div class="mb-3">
                        <input type="text" class="form-control"
                               placeholder="Buscar por placa, cliente o estado..."
                               onkeyup="filtrarTabla('tablaReservasAdmin', this.value)">
                    </div>

                    <div class="table-wrap">
                        @if (Model.Reservas.Any())
                        {
                            <table class="employee-table" id="tablaReservasAdmin">
                                <thead>
                                    <tr>
                                        <th>Cliente</th>
                                        <th>Placa</th>
                                        <th>Tipo vehiculo</th>
                                        <th>Fecha</th>
                                        <th>Hora entrada</th>
                                        <th>Hora salida</th>
                                        <th>Monto</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Reservas)
                                    {
                                        <tr>
                                            <td>@item.Cliente</td>
                                            <td>@item.Placa</td>
                                            <td>@item.TipoVehiculo</td>
                                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                            <td>@(item.HoraEntrada.HasValue ? item.HoraEntrada.Value.ToString(@"hh\:mm") : "--")</td>
                                            <td>@(item.HoraSalida.HasValue ? item.HoraSalida.Value.ToString(@"hh\:mm") : "--")</td>
                                            <td>@item.Monto.ToString("C")</td>
                                            <td>
                                                <span class="estado-badge @(item.Estado == "Pendiente" ? "estado-inactivo" : item.Estado == "Cancelada" ? "estado-cancelada" : "estado-finalizada")">
                                                    @item.Estado
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="empty-state">No hay reservas registradas.</div>
                        }
                    </div>
                </article>
            </section>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function filtrarTabla(tablaId, texto) {
            let filtro = texto.toLowerCase();
            let tabla = document.getElementById(tablaId);
            let filas = tabla.getElementsByTagName("tr");

            for (let i = 1; i < filas.length; i++) {
                let celdas = filas[i].getElementsByTagName("td");
                let cliente = celdas[0]?.textContent.toLowerCase() || "";
                let placa = celdas[1]?.textContent.toLowerCase() || "";
                let estado = celdas[7]?.textContent.toLowerCase() || "";

                filas[i].style.display = (cliente.includes(filtro) || placa.includes(filtro) || estado.includes(filtro)) ? "" : "none";
            }
        }
    </script>
</body>
</html>
