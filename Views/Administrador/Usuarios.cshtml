}
<article class="panel-card table-card">
    <h2>Empleados activos</h2>

    <input type="text" class="form-control mb-3"
           placeholder="🔍 Buscar empleado..."
           onkeyup="filtrarTabla('tablaEmpleadosActivos', this.value)">

    <div class="table-wrap">
        <table class="employee-table" id="tablaEmpleadosActivos">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Teléfono</th>
                    <th>Documento</th>
                    <th>Rol</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model.EmpleadosActivos)
                {
                    <tr>
                        <td>@emp.NombreCompleto</td>
                        <td>@emp.Correo</td>
                        <td>@emp.Telefono</td>
                        <td>@emp.TipoDocumento @emp.Documento</td>
                        <td>@emp.Rol</td>
                        <td>
                            <div class="acciones">
                                <button type="button" class="btn-table btn-detalle"
                                        onclick="abrirModalEditarUsuario(this)"
                                        data-id="@emp.Id"
                                        data-nombre="@emp.Nombre"
                                        data-apellido="@emp.Apellido"
                                        data-correo="@emp.Correo"
                                        data-telefono="@emp.Telefono"
                                        data-tipo-doc="@emp.TipoDocumento"
                                        data-rol-id="@emp.RolId">
                                    Editar
                                </button>
                                <button type="button" class="btn-table btn-salida"
                                        onclick="desactivarUsuario(@emp.Id)">
                                    Dar de baja
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</article>

