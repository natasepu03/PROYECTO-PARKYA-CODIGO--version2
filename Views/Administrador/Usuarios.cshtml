    @if (TempData["PerfilActualizado"] != null)
{
    <div id="toast" class="toast-custom">
        @TempData["PerfilActualizado"]
    </div>

    <script>
        setTimeout(() => {
            const toast = document.getElementById("toast");
            if (toast) {
                toast.classList.add("show");
            }
        }, 100);

        setTimeout(() => {
            const toast = document.getElementById("toast");
            if (toast) {
                toast.classList.remove("show");
            }
        }, 3000);
    </script>
}
@if (TempData["ParqueaderoActualizado"] != null)
