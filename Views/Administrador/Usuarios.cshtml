<div id="modalEditarPerfil" class="modal-overlay-custom">
    <div class="modal-card-custom">
        <div class="modal-header-custom">
            <h2>Editar Perfil</h2>
            <button type="button" class="modal-close-btn" onclick="cerrarModalEditarPerfil()">×</button>
        </div>

        <form method="post" action="@Url.Action("ActualizarPerfilAdmin", "Administrador")">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id_usuario" value="@Model.Administrador.id_usuario" />

            <div class="form-group-custom">
                <label for="nombre">Nombre</label>
                <input type="text" id="nombre" name="nombre" value="@Model.Administrador.nombre" required />
            </div>

            <div class="form-group-custom">
                <label for="apellido">Apellido</label>
                <input type="text" id="apellido" name="apellido" value="@Model.Administrador.apellido" required />
            </div>

            <div class="form-group-custom">
                <label for="correo">Correo</label>
                <input type="email" id="correo" name="correo" value="@Model.Administrador.correo" required />
            </div>

            <button type="submit" class="btn btn-guardar-custom">
                Guardar cambios
            </button>
        </form>
    </div>
</div>

<div id="modalEditarUsuario" class="modal-overlay-custom">
    <div class="modal-card-custom">
        <div class="modal-header-custom">
            <h2>Editar usuario</h2>
            <button type="button" class="modal-close-btn" onclick="cerrarModalEditarUsuario()">Ã—</button>
        </div>

        <form method="post" action="@Url.Action("ActualizarUsuario", "Administrador")">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editarUsuarioId" name="Id" />

            <div class="form-group-custom">
                <label for="editarNombre">Nombre</label>
                <input type="text" id="editarNombre" name="Nombre" required />
            </div>

            <div class="form-group-custom">
                <label for="editarApellido">Apellido</label>
                <input type="text" id="editarApellido" name="Apellido" required />
            </div>

            <div class="form-group-custom">
                <label for="editarCorreo">Correo</label>
                <input type="email" id="editarCorreo" name="Correo" required />
            </div>

            <div class="form-group-custom">
                <label for="editarTelefono">Telefono</label>
                <input type="text" id="editarTelefono" name="Telefono" required />
            </div>

            <div class="form-group-custom">
                <label for="editarTipoDocumento">Tipo de documento</label>
                <input type="text" id="editarTipoDocumento" name="TipoDocumento" required />
            </div>

            <div class="form-group-custom">
                <label for="editarRolId">Rol</label>
                <select id="editarRolId" name="RolId" required>
                    <option value="1">Cliente</option>
                    <option value="2">Empleado</option>
                    <option value="3">Administrador</option>
                </select>
            </div>

            <button type="submit" class="btn btn-guardar-custom">
                Guardar cambios
            </button>
        </form>
    </div>
</div>


<script>
    function abrirModalEditarPerfil() {
        const modal = document.getElementById("modalEditarPerfil");
        if (modal) {
            modal.classList.add("show");
        }
    }

    function cerrarModalEditarPerfil() {
        const modal = document.getElementById("modalEditarPerfil");
        if (modal) {
            modal.classList.remove("show");
        }
    }

    document.addEventListener("click", function (e) {
        const modal = document.getElementById("modalEditarPerfil");
        if (e.target === modal) {
            cerrarModalEditarPerfil();
        }
    });

    function abrirModalEditarUsuario(button) {
        document.getElementById("editarUsuarioId").value = button.dataset.id || "";
        document.getElementById("editarNombre").value = button.dataset.nombre || "";
        document.getElementById("editarApellido").value = button.dataset.apellido || "";
        document.getElementById("editarCorreo").value = button.dataset.correo || "";
        document.getElementById("editarTelefono").value = button.dataset.telefono || "";
        document.getElementById("editarTipoDocumento").value = button.dataset.tipoDoc || "";
        document.getElementById("editarRolId").value = button.dataset.rolId || "1";

        const modal = document.getElementById("modalEditarUsuario");
        if (modal) {
            modal.classList.add("show");
        }
    }

    function cerrarModalEditarUsuario() {
        const modal = document.getElementById("modalEditarUsuario");
        if (modal) {
            modal.classList.remove("show");
        }
    }

    document.addEventListener("click", function (e) {
        const modal = document.getElementById("modalEditarUsuario");
        if (e.target === modal) {
            cerrarModalEditarUsuario();
        }
    });

    function desactivarUsuario(id) {
    fetch('/Administrador/DesactivarUsuario', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id })
    })
    .then(() => location.reload());
}

function activarUsuario(id) {
    fetch('/Administrador/ActivarUsuario', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id })
    })
    .then(() => location.reload());
}
</script>
<script>
function filtrarTabla(idTabla, texto) {
    const filtro = texto.toLowerCase();
    const tabla = document.getElementById(idTabla);
    const filas = tabla.getElementsByTagName("tr");

    for (let i = 1; i < filas.length; i++) { // empieza en 1 para saltar el header
        const celdas = filas[i].getElementsByTagName("td");
        let coincide = false;

        for (let j = 0; j < celdas.length; j++) {
            const contenido = celdas[j].textContent.toLowerCase();

            if (contenido.includes(filtro)) {
                coincide = true;
                break;
            }
        }

        filas[i].style.display = coincide ? "" : "none";
    }
}
</script>
</body>

</html>
