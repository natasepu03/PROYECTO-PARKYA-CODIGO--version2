@model ParkYa.ViewModels.AdministradorReportesViewModel
@{
    ViewData["Title"] = "Reportes";
    var nombreCompleto = $"{Model.Administrador.nombre} {Model.Administrador.apellido}";
    var inicial = !string.IsNullOrWhiteSpace(Model.Administrador.nombre)
        ? Model.Administrador.nombre.Substring(0, 1).ToUpper()
        : "E";
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css">
        <script>
                function actualizarFechaHora() {
                    const ahora = new Date();
                    const horas = String(ahora.getHours()).padStart(2, "0");
                    const minutos = String(ahora.getMinutes()).padStart(2, "0");
                    const segundos = String(ahora.getSeconds()).padStart(2, "0");
                    const reloj = document.getElementById("reloj");
                    const fecha = document.getElementById("fecha");

                    if (reloj) {
                        reloj.textContent = `${horas}:${minutos}:${segundos}`;
                    }

                    const opcionesFecha = {
                        weekday: "long",
                        year: "numeric",
                        month: "long",
                        day: "numeric"
                    };

                    const fechaTexto = ahora.toLocaleDateString("es-ES", opcionesFecha);
                    if (fecha) {
                        fecha.textContent = fechaTexto.charAt(0).toUpperCase() + fechaTexto.slice(1);
                    }
                }

                setInterval(actualizarFechaHora, 1000);
                document.addEventListener("DOMContentLoaded", actualizarFechaHora);
        </script>
    </head>

    <body>
        <div class="layout">
            <aside class="sidebar">
                <div class="side-brand">
                    <img src="~/assets/logo1.jpeg" class="side-logo" alt="logo">
                        <div class="brand-text">
                            <h2>ParkYa</h2>
                            <span>Administrador</span>
                        </div>
                    </div>

                    <div class="side-user">
                        <div class="avatar">@inicial</div>
                        <div class="side-user-info">
                            <h3>@nombreCompleto</h3>
                            <p>@Model.Administrador.correo</p>
                        </div>
                    </div>

                    <nav class="menu">
                        <a class="item" asp-controller="Administrador" asp-action="Index">
                            <i class="bi bi-house-door"></i> Inicio
                        </a>

                        <a class="item" asp-controller="Administrador" asp-action="Usuarios">
                            <i class="bi bi-people"></i> Usuarios
                        </a>

                        <a class="item" asp-controller="Administrador" asp-action="Tarifas">
                            <i class="bi bi-cash-stack"></i> Tarifas
                        </a>

                        <a class="item" asp-controller="Administrador" asp-action="Reservas">
                            <i class="bi bi-calendar-check"></i> Reservas
                        </a>

                        <a class="item" asp-controller="Administrador" asp-action="Reportes">
                            <i class="bi bi-bar-chart"></i> Reportes
                        </a>
                    </nav>
                </aside>

                <main class="main-wrapper">
                    <header class="top-panel">
                        <div class="top-panel-left">
                            <h1>Reportes</h1>
                            <p>Indicadores, filtros e historial resumido del parqueadero</p>
                        </div>

                        <div class="top-panel-right">
                            <div class="top-info">
                                <span class="date" id="fecha"></span>
                                <span class="time" id="reloj">00:00:00</span>
                            </div>

                            <div class="top-actions">
                                <button class="btn-pill btn-danger-custom"
                                        onclick="location.href='@Url.Action("Login","Autenticacion")'">
                                    Cerrar sesion
                                </button>
                            </div>
                        </div>
                    </header>

                    <section class="dashboard-grid">
                        <article class="panel-card panel-full">
                            <h2>Filtros</h2>
                            <p class="sub">Aplica un rango de fechas para recalcular el resumen y exportar.</p>

                            <form method="get" asp-action="Reportes">
                                <div class="row align-items-end g-4">
                                    <div class="col-md-4">
                                        <label>Fecha inicio</label>
                                        <input type="date" name="fechaInicio"
                                               value="@(Model.FechaInicio?.ToString("yyyy-MM-dd"))" class="form-control" />
                                    </div>
                                    <div class="col-md-4">
                                        <label>Fecha fin</label>
                                        <input type="date" name="fechaFin" value="@(Model.FechaFin?.ToString("yyyy-MM-dd"))"
                                               class="form-control" />
                                    </div>
                                    <div class="col-md-2">
                                        <button type="submit" class="btn btn-guardar-custom">Filtrar</button>
                                    </div>
                                    <div class="col-md-2">
                                        <a class="btn btn-guardar-custom"
                                           href="@Url.Action("ExportarReportes", "Administrador", new { fechaInicio = Model.FechaInicio?.ToString("yyyy-MM-dd"), fechaFin = Model.FechaFin?.ToString("yyyy-MM-dd") })">Exportar</a>
                                    </div>
                                </div>
                            </form>
                        </article>

                        <article class="panel-card">
                            <h2>Reservas</h2>
                            <p class="sub">Totales del sistema por periodo general.</p>
                            <div class="summary-stats">
                                <div class="stat-mini">
                                    <span>Dia</span>
                                    <strong>@Model.TotalReservasDia</strong>
                                </div>
                                <div class="stat-mini">
                                    <span>Semana</span>
                                    <strong>@Model.TotalReservasSemana</strong>
                                </div>
                                <div class="stat-mini">
                                    <span>Mes</span>
                                    <strong>@Model.TotalReservasMes</strong>
                                </div>
                            </div>
                        </article>

                        <article class="panel-card">
                            <h2>Estados</h2>
                            <p class="sub">Conteo del rango filtrado.</p>
                            <div class="summary-stats">
                                <div class="stat-mini">
                                    <span>Pendientes</span>
                                    <strong>@Model.ReservasPendientes</strong>
                                </div>
                                <div class="stat-mini">
                                    <span>Finalizadas</span>
                                    <strong>@Model.ReservasFinalizadas</strong>
                                </div>
                                <div class="stat-mini">
                                    <span>Canceladas</span>
                                    <strong>@Model.ReservasCanceladas</strong>
                                </div>
                            </div>
                        </article>

                        <article class="panel-card">
                            <h2>Ingresos</h2>
                            <p class="sub">Valores calculados para el rango filtrado.</p>
                            <div class="summary-stats">
                                <div class="stat-mini">
                                    <span>Total real</span>
                                    <strong>@Model.IngresosReales.ToString("C")</strong>
                                </div>
                                <div class="stat-mini">
                                    <span>Monto promedio</span>
                                    <strong>@Model.MontoPromedio.ToString("C")</strong>
                                </div>
                            </div>
                        </article>

                        <article class="panel-card">
                            <h2>Hora pico</h2>
                            <p class="sub">Franja horaria con mayor cantidad de reservas en el rango filtrado.</p>
                            <div class="summary-stats">
                                <div class="stat-mini">
                                    <span>Hora</span>
                                    <strong>@Model.HoraPico</strong>
                                </div>
                                <div class="stat-mini">
                                    <span>Total reservas</span>
                                    <strong>@Model.TotalReservasHoraPico</strong>
                                </div>
                            </div>
                        </article>

                        <article class="panel-card table-card panel-full">
                            <h2>Detalle del rango</h2>
                            <p class="sub">Listado resumido de reservas segun el filtro aplicado.</p>
                            <div class="table-wrap">
                                @if (Model.ReservasFiltradas.Any())
                                {
                                    <table class="employee-table">
                                        <thead>
                                            <tr>
                                                <th>Cliente</th>
                                                <th>Placa</th>
                                                <th>Tipo vehiculo</th>
                                                <th>Fecha</th>
                                                <th>Monto</th>
                                                <th>Estado</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.ReservasFiltradas)
                                            {
                                                <tr>
                                                    <td>@item.Cliente</td>
                                                    <td>@item.Placa</td>
                                                    <td>@item.TipoVehiculo</td>
                                                    <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                                    <td>@item.Monto.ToString("C")</td>
                                                    <td>
                                                        <span
                                                            class="estado-badge @(item.Estado == "Pendiente" ? "estado-inactivo" : item.Estado == "Cancelada" ? "estado-cancelada" : "estado-finalizada")">
                                                            @item.Estado
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <div class="empty-state">No hay reservas para el rango seleccionado.</div>
                                }
                            </div>
                        </article>
                    </section>
                </main>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        </body>

    </html>
