@model ParkYa.ViewModels.AdministradorTarifasViewModel
@{
    ViewData["Title"] = "Tarifas";
    var nombreCompleto = $"{Model.Administrador.nombre} {Model.Administrador.apellido}";
    var inicial = !string.IsNullOrWhiteSpace(Model.Administrador.nombre)
        ? Model.Administrador.nombre.Substring(0, 1).ToUpper()
        : "E";
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css">
        <script>
                function actualizarFechaHora() {
                    const ahora = new Date();
                    const horas = String(ahora.getHours()).padStart(2, "0");
                    const minutos = String(ahora.getMinutes()).padStart(2, "0");
                    const segundos = String(ahora.getSeconds()).padStart(2, "0");

                    const reloj = document.getElementById("reloj");
                    const fecha = document.getElementById("fecha");

                    if (reloj) {
                        reloj.textContent = `${horas}:${minutos}:${segundos}`;
                    }

                    const opcionesFecha = {
                        weekday: "long",
                        year: "numeric",
                        month: "long",
                        day: "numeric"
                    };

                    const fechaTexto = ahora.toLocaleDateString("es-ES", opcionesFecha);

                    if (fecha) {
                        fecha.textContent = fechaTexto.charAt(0).toUpperCase() + fechaTexto.slice(1);
                    }
                }

                setInterval(actualizarFechaHora, 1000);
                document.addEventListener("DOMContentLoaded", actualizarFechaHora);
        </script>
    </head>

    <body>
        <div class="layout">
            <aside class="sidebar">
                <div class="side-brand">
                    <img src="~/assets/logo1.jpeg" class="side-logo" alt="logo">
                        <div class="brand-text">
                            <h2>ParkYa</h2>
                            <span>Administrador</span>
                        </div>
                    </div>

                    <div class="side-user">
                        <div class="avatar">@inicial</div>
                        <div class="side-user-info">
                            <h3>@nombreCompleto</h3>
                            <p>@Model.Administrador.correo</p>
                        </div>
                    </div>

                    <nav class="menu">
                        <a class="item" asp-controller="Administrador" asp-action="Index">
                            <i class="bi bi-house-door"></i> Inicio
                        </a>

                        <a class="item" asp-controller="Administrador" asp-action="Usuarios">
                            <i class="bi bi-people"></i> Usuarios
                        </a>

                        <a class="item" asp-controller="Administrador" asp-action="Tarifas">
                            <i class="bi bi-cash-stack"></i> Tarifas
                        </a>

                        <a class="item" asp-controller="Administrador" asp-action="Reservas">
                            <i class="bi bi-calendar-check"></i> Reservas
                        </a>

                        <a class="item" asp-controller="Administrador" asp-action="Reportes">
                            <i class="bi bi-bar-chart"></i> Reportes
                        </a>
                    </nav>
                </aside>

                <main class="main-wrapper">
                    <header class="top-panel">
                        <div class="top-panel-left">
                            <h1>Tarifas</h1>
                            <p>Configura precios por tipo de vehiculo</p>
                        </div>

                        <div class="top-panel-right">
                            <div class="top-info">
                                <span class="date" id="fecha"></span>
                                <span class="time" id="reloj">00:00:00</span>
                            </div>

                            <div class="top-actions">
                                <button class="btn-pill btn-danger-custom"
                                        onclick="location.href='@Url.Action("Login","Autenticacion")'">
                                    Cerrar sesion
                                </button>
                            </div>
                        </div>
                    </header>

                    <section class="dashboard-grid">
                        <article class="panel-card">
                            <h2>Resumen de tarifas</h2>
                            <p class="sub">Consulta y actualiza los precios de cada tipo de vehiculo.</p>

                            <div class="summary-stats">
                                <div class="stat-mini">
                                    <span>Total tarifas</span>
                                    <strong>@Model.Tarifas.Count</strong>
                                </div>
                            </div>
                        </article>

                        @if (TempData["MensajeTarifas"] != null)
                        {
                            <div class="users-feedback users-feedback-success" role="status">
                                @TempData["MensajeTarifas"]
                            </div>
                        }

                        @if (TempData["ErrorTarifas"] != null)
                        {
                            <div class="users-feedback users-feedback-error" role="alert">
                                @TempData["ErrorTarifas"]
                            </div>
                        }

                        <article class="panel-card panel-full">
                            <h2>Tarifas por vehiculo</h2>
                            <p class="sub">Edita el precio por dia y por hora de cada tarifa.</p>

                            <div class="tarifas-stack">
                                @foreach (var tarifa in Model.Tarifas)
                                {
                                    <form asp-action="ActualizarTarifa" method="post" class="tarifa-block">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Id" value="@tarifa.Id" />

                                        <div class="tarifa-block-head">
                                            <div>
                                                <span class="tarifa-kicker">Tipo de vehiculo</span>
                                                <h3>@tarifa.TipoVehiculo</h3>
                                            </div>
                                            <span class="tarifa-code">@tarifa.Codigo</span>
                                        </div>

                                        <div class="tarifa-meta">
                                            <div class="tarifa-meta-item">
                                                <span>Horario</span>
                                                <strong>@tarifa.Horario</strong>
                                            </div>
                                        </div>

                                        <div class="row g-4 align-items-end">
                                            <div class="col-md-5">
                                                <label>Precio dia</label>
                                                <input type="number" step="0.01" min="0" name="PrecioDia" value="@tarifa.PrecioDia"
                                                       class="form-control" />
                                            </div>

                                            <div class="col-md-5">
                                                <label>Precio hora</label>
                                                <input type="number" step="0.01" min="0" name="PrecioHora"
                                                       value="@tarifa.PrecioHora" class="form-control" />
                                            </div>

                                            <div class="col-md-2">
                                                <button type="submit" class="btn btn-guardar-custom">
                                                    Guardar
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                }
                            </div>
                        </article>
                    </section>
                </main>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        </body>

    </html>
